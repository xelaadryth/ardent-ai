        "dayDisplayCallback": "/**\n * Calendarium Day Callback for the Rosharan Calendar (Supports Pre-Epoch)\n * Formats absolute day indices into standard Vorin notation: YYYY.M.W.D\n * Supports negative timeline integers for historical worldbuilding notes.\n * \n * @param {number} totalDays - The absolute cumulative day of the calendar\n * @returns {string} The formatted Rosharan date string (Negative if Pre-Epoch)\n */\nfunction getRosharanDate(totalDays) {\n    // Rosharan calendar constants\n    const DAYS_IN_WEEK = 5;\n    const DAYS_IN_MONTH = 50;\n    const DAYS_IN_YEAR = 500;\n\n    if (totalDays >= 1) {\n        // --- Standard Post-Epoch Math ---\n        const zeroIndexedDays = totalDays - 1;\n\n        const year = Math.floor(zeroIndexedDays / DAYS_IN_YEAR) + 1;\n        const dayOfYear = zeroIndexedDays % DAYS_IN_YEAR;\n\n        const month = Math.floor(dayOfYear / DAYS_IN_MONTH) + 1;\n        const dayOfMonth = dayOfYear % DAYS_IN_MONTH;\n\n        const week = Math.floor(dayOfMonth / DAYS_IN_WEEK) + 1;\n        const dayOfWeek = (dayOfMonth % DAYS_IN_WEEK) + 1;\n\n        return `${year}.${month}.${week}.${dayOfWeek}`;\n    } else {\n        // --- Pre-Epoch Math (Counting backward from Day 1) ---\n        // Convert to a positive distance backward from the start of Year 1\n        const daysBeforeEpoch = 1 - totalDays; \n\n        const year = -Math.floor((daysBeforeEpoch - 1) / DAYS_IN_YEAR) - 1;\n        const dayOfYear = (daysBeforeEpoch - 1) % DAYS_IN_YEAR;\n\n        // Invert the month/week/day alignment so they count 1 to 10 within that negative year\n        const inverseDayOfYear = (DAYS_IN_YEAR - 1) - dayOfYear;\n\n        const month = Math.floor(inverseDayOfYear / DAYS_IN_MONTH) + 1;\n        const dayOfMonth = inverseDayOfYear % DAYS_IN_MONTH;\n\n        const week = Math.floor(dayOfMonth / DAYS_IN_WEEK) + 1;\n        const dayOfWeek = (dayOfMonth % DAYS_IN_WEEK) + 1;\n\n        // Returns a negative year prefix: e.g., -100.10.10.5\n        return `${year}.${month}.${week}.${dayOfWeek}`;\n    }\n}"
